{
  "app": {
    "name": "incident-management-service",
    "environment": "local",
    "host": "127.0.0.1",
    "port": 8000
  },
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s %(levelname)s [%(name)s] [corr=%(correlation_id)s] %(message)s"
  },
  "storage": {
    "raw_data_dir": "data/raw",
    "processed_data_dir": "data/processed"
  },
  "ingestion": {
    "error_data_dir": "error_data",
    "default_csv_file": "error_prefix_counts.csv"
  },
  "database": {
    "url": "sqlite:///./data/app.db"
  },
  "vector_store": {
    "provider": "chroma",
    "persist_directory": "data/chroma",
    "collection_name": "incident_kb",
    "telemetry_enabled": false
  },
  "knowledge_base": {
    "seed_file": "config/knowledge_base.json",
    "max_results": 3,
    "direct_match_threshold": 0.75
  },
  "models": {
    "primary_llm": "gpt-4.1-mini",
    "verification_llm": "gpt-4.1-mini",
    "verification_provider": "openai",
    "verification_api_key_env_var": "OPENAI_API_KEY",
    "embedding_provider": "local_hash",
    "embedding_model": "local-hash-256",
    "embedding_dimensions": 256,
    "openai_api_key_env_var": "OPENAI_API_KEY",
    "temperature": 0.0
  },
  "search": {
    "enabled": true,
    "provider": "tavily",
    "api_key_env_var": "TAVILY_API_KEY",
    "max_results": 3,
    "search_depth": "basic"
  },
  "classification": {
    "taxonomy_file": "config/classification_taxonomy.json"
  },
  "workflow": {
    "allow_direct_kb_resolution": true,
    "verification_confidence_threshold": 0.6,
    "refinement_confidence_threshold": 0.7,
    "use_web_search_on_low_confidence": true,
    "update_kb_on_verified": true,
    "max_classification_retries": 1,
    "max_refinement_retries": 1,
    "route_failed_verification_to_human_review": true,
    "route_failed_refinement_to_human_review": true
  },
  "langsmith": {
    "enabled": false,
    "project": "incident-triaging-n-resolutions",
    "endpoint": "https://api.smith.langchain.com",
    "api_key_env_var": "LANGSMITH_API_KEY",
    "run_name": "incident-error-workflow"
  }
}
